# Telegram (Telethon requires all 3)
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELETHON_SESSION_PATH=data/tg-bot.session

# Optional proxy for Telegram + Gemini requests
# Example: socks5://user:pass@127.0.0.1:1080
OUTBOUND_PROXY=

# Google Sheets
GOOGLE_SHEET_URL=
GOOGLE_WORKSHEET_NAME=Расходы
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/google-service-account.json
QUEUE_DB_PATH=data/message_queue.sqlite3

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Retry/backoff tuning
# Backoff sequence for retries: base*1, base*2, base*4, base*8 => default 2,4,8,16
RETRY_BACKOFF_BASE_SECONDS=2
GEMINI_TRANSIENT_RETRIES=4
GEMINI_VALIDATION_RETRIES=2
GEMINI_TIMEOUT_SECONDS=45
GOOGLE_APPEND_RETRIES=4
PIPELINE_RETRY_MAX_BACKOFF_SECONDS=300
QUEUE_POLL_INTERVAL_SECONDS=1

# Bot behavior
ALLOW_GROUP_CHATS=false
ALLOWED_CHAT_IDS=
LOG_LEVEL=INFO
